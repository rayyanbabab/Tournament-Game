# Environment Variables — Copy to .env.local and fill in values

# ── NextAuth ──────────────────────────────────────────────────────
AUTH_SECRET=your-random-secret-here-min-32-chars
NEXTAUTH_URL=https://your-domain.vercel.app

# ── Neon PostgreSQL ───────────────────────────────────────────────
DATABASE_URL=postgresql://neondb_owner:password@ep-xxxx.neon.tech/neondb?sslmode=require&channel_binding=require

